# MongoDB Atlas connection string.
# Create this in MongoDB Atlas: Database > Connect > Drivers.
# Example format: mongodb+srv://USERNAME:PASSWORD@cluster-name.mongodb.net/nqs
MONGO_URI=

# JWT signing secret for login tokens.
# Use a long, random value in real deployment.
JWT_SECRET=

PORT=5001
FRONTEND_URL=http://localhost:5173

# Gmail SMTP settings.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587

# Your Gmail address, for example: myemail@gmail.com
SMTP_USER=

# Your Gmail App Password, not your normal Gmail password.
# Generate it from Google Account > Security > 2-Step Verification > App passwords.
SMTP_PASS=

# Sender name and email shown to users.
# Example: NQS National ID <myemail@gmail.com>
SMTP_FROM=
