# Base URL of the backend API.
# Leave empty for local development: the Vite dev server proxies /api and
# /socket.io to http://localhost:5001 (see vite.config.js).
# For production (Vercel), set it to the deployed backend URL, for example:
# VITE_API_URL=https://your-render-backend.onrender.com
VITE_API_URL=
